    given-names: Thomas
    email: thequantumfalcon@gmail.com
repository-code: "https://github.com/thequantumfalcon/kry"
url: "https://github.com/thequantumfalcon/kry"
version: "0.1.2"
date-released: "2026-07-21"
license: Apache-2.0
keywords:
